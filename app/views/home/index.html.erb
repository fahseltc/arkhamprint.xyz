<%= render "partials/modals" %>

<p class="m-3">ArkhamPrint.XYZ is a tool to help players of the Arkham Horror LCG to print out proxy decks at home.</p>

<p class="m-3 pb-3">It uses <%= link_to "ArkhamDB", "https://arkhamdb.com", target: :_blank %> as the source of card images and can accept either a ArkhamDB decklist, or a list of individual card IDs.</p>

<nav>
  <div class=" nav nav-tabs" id="nav-tab" role="tablist">
    <button class="nav-link active" id="nav-deck-tab" data-bs-toggle="tab" data-bs-target="#nav-deck" type="button" role="tab" aria-controls="nav-deck" aria-selected="true">
      Deck URL
    </button>
    <button class="nav-link" id="nav-card-tab" data-bs-toggle="tab" data-bs-target="#nav-card" type="button" role="tab" aria-controls="nav-card" aria-selected="false">
      Individual Card IDs
    </button>
  </div>
</nav>
<div class="tab-content mx-auto" id="nav-tabContent">
  <div class="tab-pane fade show active p-3" id="nav-deck" role="tabpanel" aria-labelledby="nav-deck-tab">
    <label for="deck_url">ArkhamDB deck URL</label>
    <input type="text" class="form-control" id="deck_url" name="deck_url" placeholder="https://arkhamdb.com/decklist/view/48985">
    <!--<button type="button" class="btn btn-primary mt-3" onClick="submitFromDeckForm()">
      Get PDF
    </button> -->
    <button type="button" class="btn btn-primary mt-3" onClick="submitByDeckUrl()">
      Get PDF
    </button> <!-- TODO: this button should do input validation first, then open the google modal.-->
  </div>

  <div class="tab-pane fade p-3" id="nav-card" role="tabpanel" aria-labelledby="nav-card-tab">
    <label for="card_ids">ArkhamDB card ID's seperated by commas</label>
    <input type="text" class="form-control" id="card_ids" name="card_ids" placeholder="01022, 01044">
    <button type="button" class="btn btn-primary mt-3" onClick="submitByCardId()">
      Get PDF
    </button>
    <!-- data-bs-toggle="modal" data-bs-target="#byCardIdModal" -->
    <!-- onClick="submitFromCardIdForm()" -->
  </div>
</div>


<script>
  // FromDeck entrypoint method
  async function submitFromDeckForm() {
    var input = $('#deck_url').val();
    console.log(input);
    var valid = validateDeckUrl(input);
    if (!valid) {
      alert("ArkhamDB Deck URL is invalid!");
      return;
    }
    const url = "/job/from_deck?" + new URLSearchParams({
      deck_url: input
    });
    hideAndShowLoading("byDeckUrlModalContent", "byDeckUrlModalLoading");
    await submitJob(url);
    await new Promise(resolve => setTimeout(resolve, 5000));
    await pollAndDownload();
    $("#byDeckUrlModal").modal("hide")
    grecaptcha.reset();
    hideAndShowLoading("byDeckUrlModalLoading", "byDeckUrlModalContent");
  }

  // FromCardIDs entrypoint method
  async function submitFromCardIdForm() {
    var input = $('#card_ids').val();
    input = input.replace(/ /g, "").split(',');
    // input was already validated on btn click
    const url = "/job/from_card_list?" + new URLSearchParams({
      card_ids: input
    });
    hideAndShowLoading("byCardIdModalContent", "byCardIdModalLoading");
    await submitJob(url);
    await pollAndDownload();
    $("#byCardIdModal").modal("hide")
    grecaptcha.reset();
    hideAndShowLoading("byCardIdModalLoading", "byCardIdModalContent");
  }

  function submitByCardId() {
    var input = $('#card_ids').val().replace(/ /g, "").split(',');
    var valid = validateCardIdArray(input);
    if (valid) {
      $("#card_ids").css("border", "1px solid lightgreen");
      $("#byCardIdModal").modal("show"); // Open captcha modal
      return true;
    } else {
      $("#card_ids").css("border", "1px solid red");
      return false;
    }
  }

  function validateCardIdArray(input) {
    if (input.length == 0) {
      return false
    }
    for (const element of input) {
      if (!/\d/.test(element)) {
        return false;
      }
    };
    return true
  }

  function submitByDeckUrl() {
    var input = $('#deck_url').val();
    var valid = validateDeckUrl(input);
    if (valid) {
      $("#deck_url").css("border", "1px solid lightgreen");
      $("#byDeckUrlModal").modal("show"); // Open captcha modal
      return true;
    } else {
      $("#deck_url").css("border", "1px solid red");
      return false;
    }
  }

  function validateDeckUrl(input) {
    // expected input: https://arkhamdb.com/decklist/view/48985
    if (input == undefined) {
      input = $('#deck_url').val();
    }
    return new RegExp('arkhamdb.com/decklist/view/').test(input);
  }

  async function submitJob(url) {
    const rawResponse = await fetch(url);
    const response = await rawResponse.json();
    console.log("JobID: " + response["job_id"]);
    console.log("FileID: " + response["file_id"]);
    if (rawResponse.ok) {
      console.log("setting local storage");
      sessionStorage.setItem("FileID", response["file_id"]);
      sessionStorage.setItem("JobID", response["job_id"]);
    } else {
      alert("There was a problem submitting the job to the server. Please try again later.");
      sessionStorage.clear();
    }
  }

  async function pollAndDownload() {
    var success = await downloadPdfAndRetry(0);
    console.log("downloadPdfAndRetry result: " + success)
    if (success) {
      await new Promise(resolve => setTimeout(resolve, 2000));
      sessionStorage.clear();
    } else {
      alert("The maximum duration of 80 seconds has passed and your cards failed to be processed. Please try again later!");
    }
  }

  async function downloadPdfAndRetry(timeWaited) {
    if (timeWaited > 80000) {
      return false;
    }
    console.log("Seconds waited: " + timeWaited / 1000);
    file_id = sessionStorage.getItem("FileID");
    const url = "/job/download?" + new URLSearchParams({
      file_id: file_id
    });
    const rawResponse = await fetch(url);
    if (rawResponse.status == "200") {
      const blob = await rawResponse.blob();
      var file = window.URL.createObjectURL(blob);
      window.open(file, '_blank');
      return true;
    } else {
      timeWaited += 3000;
      await new Promise(resolve => setTimeout(resolve, 3000));
      return await downloadPdfAndRetry(timeWaited);
    }
  }


