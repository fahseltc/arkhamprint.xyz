  //     console.error("error in callPdfApi")
  //     console.error(error.message);
  //     console.error(error.cause);
  //   }
  // }

  function hideAndShowLoading(id_to_hide, id_to_show) {
    $("#" + id_to_hide).hide();
    $("#" + id_to_show).show();
  }
</script>